{
  "name": "@workspace/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "build:serverless": "node ./build.serverless.mjs",
    "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@vercel/blob": "^2.3.1",
    "@workspace/api-client": "workspace:*",
