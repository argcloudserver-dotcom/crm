    "@workspace/db": "workspace:*",
    "@workspace/permissions": "workspace:*",
    "@workspace/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^3.0.3",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "file-type": "^19.0.0",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "resend": "^6.12.4",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
