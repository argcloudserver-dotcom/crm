NODE_ENV=""
PORT=4000

# Local dev: matches docker-compose.yml (`docker compose up -d db`).
# In production, set this to your real database URL.
DATABASE_URL=""

# Freshly generated; do NOT reuse the previously exposed values from any
# earlier copy of this project. Regenerate before production.
JWT_SECRET=""
JWT_REFRESH_SECRET=""
SESSION_SECRET=""
CSRF_SECRET=""

ACCESS_TOKEN_TTL=""
REFRESH_TOKEN_TTL=""
CORS_ORIGINS=""

PUBLIC_APP_URL=""

# ── Auth ────────────────────────────────────────────────────────────────────
# mock = no provider secrets needed; /auth/google and /auth/facebook
#        log in a deterministic mock user. Forbidden in production.
# real = use the GOOGLE_/FACEBOOK_ credentials below.
AUTH_MODE=""

# Only needed when AUTH_MODE=real. Leave blank to use mock OAuth in dev.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Optional: only set if the API talks to Supabase server-side.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
